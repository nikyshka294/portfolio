            <button className="px-10 py-4 rounded-full font-semibold transition text-lg" style={{borderWidth: '2px', borderColor: '#067cfe', color: '#067cfe', backgroundColor: 'transparent'}} onMouseEnter={(e) => e.target.style.backgroundColor = 'rgba(6, 124, 254, 0.1)'} onMouseLeave={(e) => e.target.style.backgroundColor = 'transparent'}>
              Email: hello@portfolio.com
            </button>
          </div>
        </div>
      </section>

      {/* Footer */}
      <footer className="border-t border-gray-200 py-12 px-6">
        <div className="max-w-7xl mx-auto text-center text-gray-600">
          <p>© 2024 Portfolio. Все права защищены.</p>
        </div>
      </footer>

      {/* Video Modal */}
      {selectedVideo && (
        <div 
          className="fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4"
          onClick={() => setSelectedVideo(null)}
        >
          <div 
            className="bg-black rounded-lg w-full max-w-3xl"
            onClick={(e) => e.stopPropagation()}
          >
            <div className="relative pt-[56.25%]">
              <video
                src={selectedVideo}
                controls
                autoPlay
                className="absolute top-0 left-0 w-full h-full rounded-lg"
              />
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

